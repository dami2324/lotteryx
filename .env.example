# ── Resend (emails) ──────────────────────────────────────────────────────────
# Get your API key at: https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Sender address (must be verified in Resend)
# For testing you can leave the default: onboarding@resend.dev
EMAIL_FROM=LotteryX <picks@yourdomain.com>

# ── Upstash Redis (user storage) ─────────────────────────────────────────────
# Create a free database at: https://console.upstash.com
# Copy the REST URL and Token from the database details page
KV_REST_API_URL=https://xxxx.upstash.io
KV_REST_API_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Cron secret (optional but recommended) ───────────────────────────────────
# Vercel will send this header when invoking the cron endpoint
# Generate a random string: openssl rand -hex 32
CRON_SECRET=your_random_secret_here
